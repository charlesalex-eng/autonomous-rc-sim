<?xml version="1.0"?>
<robot name="rc_car">

  <!-- CHASSIS -->
  <link name="chassis">
    <visual>
      <geometry>
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- FRONT LEFT WHEEL -->
  <link name="wheel_front_left">
    <visual>
      <geometry>
        <mesh filename="meshes/wheel_front_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.050" length="0.042"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wheel_front_left" type="revolute">
    <parent link="chassis"/>
    <child link="wheel_front_left"/>
    <origin xyz="0.310 0.15 0.035" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="100"/>
  </joint>

  <!-- FRONT RIGHT WHEEL -->
  <link name="wheel_front_right">
    <visual>
      <geometry>
        <mesh filename="meshes/wheel_front_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.050" length="0.042"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wheel_front_right" type="revolute">
    <parent link="chassis"/>
    <child link="wheel_front_right"/>
    <origin xyz="0.310 -0.160 0.035" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="100"/>
  </joint>

  <!-- REAR LEFT WHEEL -->
  <link name="wheel_rear_left">
    <visual>
      <geometry>
        <mesh filename="meshes/wheel_rear_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0535" length="0.053"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wheel_rear_left" type="revolute">
    <parent link="chassis"/>
    <child link="wheel_rear_left"/>
    <origin xyz="-0.095 0.150 0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="100"/>
  </joint>

  <!-- REAR RIGHT WHEEL -->
  <link name="wheel_rear_right">
    <visual>
      <geometry>
        <mesh filename="meshes/wheel_rear_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0535" length="0.053"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wheel_rear_right" type="revolute">
    <parent link="chassis"/>
    <child link="wheel_rear_right"/>
    <origin xyz="-0.095 -0.16 0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="100"/>
  </joint>

</robot>